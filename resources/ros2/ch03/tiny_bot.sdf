<?xml version="1.0" ?>
<!--
  tiny_bot.sdf — Gazebo Sim ("Harmonic") model for tiny_bot.

  4-wheel differential-drive robot. Mirrors the URDF (tiny_bot.urdf.xacro)
  link/joint hierarchy with the same link names, plus Gazebo-specific
  <plugin> blocks and a <sensor> for the IR distance reading.

  Layout:
    - chassis (base_link) — 0.30 x 0.20 x 0.10 m box, centred at the model origin.
    - 4 wheels (fl, fr, rl, rr) — radius 0.05, thickness 0.02.
    - ir_front — small box visual + 1-ray gpu_lidar sensor.
  Driven: front wheels (fl, fr). Rear wheels (rl, rr) spin passively in their
  continuous joints, providing four-point stability without needing a caster.

  Geometry (all in metres):
    Wheel centres at z = 0.05 absolute (wheel_radius), so wheel bottoms touch
    the ground at z = 0. The chassis sits above the wheels: chassis bottom at
    z = 0.10 (wheel top), chassis centre at z = 0.15 (model origin is here).
-->
<sdf version="1.8">
  <model name="tiny_bot">
    <pose>0 0 0.15 0 0 0</pose>

    <!-- Chassis. COM lowered to make the robot bottom-heavy. -->
    <link name="base_link">
      <inertial>
        <pose>0 0 -0.04 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0083</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0167</iyy><iyz>0</iyz>
          <izz>0.0217</izz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry>
          <box><size>0.30 0.20 0.10</size></box>
        </geometry>
      </collision>
      <visual name="chassis_visual">
        <geometry>
          <box><size>0.30 0.20 0.10</size></box>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.45 1.0</ambient>
          <diffuse>0.4 0.4 0.45 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Wheel template macro repeated four times. Each wheel link is rotated
         90° about its own x-axis so the cylinder lies on its side (Gazebo's
         default cylinder stands along its own z-axis). Center is at
         (±wheel_x_offset, ±wheel_y_offset, -0.10) relative to model. -->

    <!-- Front-left -->
    <link name="fl_wheel">
      <pose>0.10 0.12 -0.10 -1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7e-5</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>7e-5</iyy><iyz>0</iyz>
          <izz>1.25e-4</izz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- Front-right -->
    <link name="fr_wheel">
      <pose>0.10 -0.12 -0.10 -1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7e-5</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>7e-5</iyy><iyz>0</iyz>
          <izz>1.25e-4</izz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- Rear-left -->
    <link name="rl_wheel">
      <pose>-0.10 0.12 -0.10 -1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7e-5</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>7e-5</iyy><iyz>0</iyz>
          <izz>1.25e-4</izz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- Rear-right -->
    <link name="rr_wheel">
      <pose>-0.10 -0.12 -0.10 -1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7e-5</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>7e-5</iyy><iyz>0</iyz>
          <izz>1.25e-4</izz>
        </inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- Front IR distance sensor. See tiny_bot.urdf.xacro for matching link. -->
    <link name="ir_front">
      <pose>0.18 0 0.02 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name="ir_front_visual">
        <!-- visual sits 1.5cm behind the link origin so the +x ray doesn't see it -->
        <pose>-0.015 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.02 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.9 0.5 0.1 1.0</ambient>
          <diffuse>0.9 0.5 0.1 1.0</diffuse>
        </material>
      </visual>
      <sensor name="ir_front_sensor" type="gpu_lidar">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <topic>ir_front</topic>
        <gz_frame_id>ir_front</gz_frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>1</samples>
              <resolution>1.0</resolution>
              <min_angle>0.0</min_angle>
              <max_angle>0.0</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>1.5</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <!-- Joints. All wheels are continuous (free rotation). -->
    <joint name="fl_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>fl_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>10</effort></limit>
      </axis>
    </joint>

    <joint name="fr_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>fr_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>10</effort></limit>
      </axis>
    </joint>

    <joint name="rl_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rl_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>10</effort></limit>
      </axis>
    </joint>

    <joint name="rr_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rr_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>10</effort></limit>
      </axis>
    </joint>

    <joint name="ir_front_joint" type="fixed">
      <parent>base_link</parent>
      <child>ir_front</child>
    </joint>

    <!-- Plugins -->

    <!-- Diff-drive: only the FRONT wheels are commanded. The rear pair are
         passive — they spin freely in their continuous joints. Wheel_separation
         is the front-axle track (same as rear, since y_offset is identical).
         A real 4WD Arduino car typically links all four wheels mechanically;
         in sim, "drive the front two and let the rear two roll" is the
         simplest faithful model that exercises the same Twist→odom contract. -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>fl_wheel_joint</left_joint>
      <right_joint>fr_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
      <tf_topic>/tf</tf_topic>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>fl_wheel_joint</joint_name>
      <joint_name>fr_wheel_joint</joint_name>
      <joint_name>rl_wheel_joint</joint_name>
      <joint_name>rr_wheel_joint</joint_name>
    </plugin>

  </model>
</sdf>
